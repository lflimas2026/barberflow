# API URL (your Cloudflare Workers endpoint)
VITE_API_URL=http://localhost:8787

# Google OAuth
VITE_GOOGLE_CLIENT_ID=

# Asaas Payment Gateway (https://www.asaas.com/)
# Get your API key at: https://sandbox.asaas.com (sandbox) or https://www.asaas.com (production)
ASAAS_API_KEY=
# Set to 'sandbox' for testing, 'production' for live
ASAAS_ENVIRONMENT=sandbox

# JWT Secret for auth tokens
JWT_SECRET=your-secret-key-change-in-production

# WhatsApp Business API
WHATSAPP_API_KEY=
